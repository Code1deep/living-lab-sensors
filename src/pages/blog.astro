---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('blog');
articles.sort((a, b) => b.data.pubDate.localeCompare(a.data.pubDate));
---

<BaseLayout title="Blog DBR" description="Documentation de ma démarche Design-Based Research">
  <section>
    <h1 class="text-3xl font-bold text-center mb-2">Blog – Documentation DBR</h1>
    <p class="text-center text-gray-500 mb-8">Cycles d'itération, obstacles cognitifs, analyses de terrain</p>
    
    <div class="grid gap-6 max-w-3xl mx-auto">
      {articles.map((article) => (
        <article class="border-b pb-6">
          <h2 class="text-xl font-bold text-blue-800 mb-2">
            <a href={"/blog/" + article.slug} class="hover:underline">{article.data.title}</a>
          </h2>
          <p class="text-gray-500 text-sm mb-2">{article.data.pubDate} – 5 min de lecture</p>
          <p class="text-gray-700">{article.data.description}</p>
          <a href={"/blog/" + article.slug} class="text-blue-600 text-sm mt-2 inline-block">Lire l'article →</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
